{
	"name": "@zokugun/vscode-utils",
	"description": "Some utilities for VSCode extensions",
	"version": "0.3.0",
	"author": {
		"name": "Baptiste Augrain",
		"email": "daiyam@zokugun.org"
	},
	"license": "MIT",
	"homepage": "https://github.com/zokugun/vscode-utils",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/zokugun/vscode-utils.git"
	},
	"bugs": {
		"url": "https://github.com/zokugun/vscode-utils/issues"
	},
	"main": "lib/index.js",
	"scripts": {
		"build": "npm run compile:src",
		"compile:src": "tsc -p src",
		"lint": "xo",
		"lint:fix": "xo --fix",
		"prepare": "husky; fixpack || true",
		"prepublishOnly": "npm run build",
		"release": "release-it",
		"watch:src": "tsc-watch -p src"
	},
	"dependencies": {
		"@zokugun/fs-extra-plus": "^0.3.6",
		"@zokugun/xtry": "^0.11.1"
	},
	"devDependencies": {
		"@commitlint/cli": "^19.7.1",
		"@commitlint/config-conventional": "^19.7.1",
		"@types/node": "^20.14.8",
		"@types/vscode": "^1.23.0",
		"fixpack": "^4.0.0",
		"husky": "^9.1.7",
		"lint-staged": "^16.1.4",
		"release-it": "^19.2.4",
		"tsc-watch": "^7.2.0",
		"typescript": "^5.7.3",
		"xo": "0.60.0"
	},
	"overrides": {
		"terser-webpack-plugin": {
			"serialize-javascript": "^7.0.3"
		}
	},
	"keywords": []
}
