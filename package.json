{
	"name": "@zokugun/vscode-utils",
	"description": "Some utilities for VSCode extensions",
	"version": "0.3.0",
	"author": {
		"name": "Baptiste Augrain",
		"email": "daiyam@zokugun.org"
	},
	"license": "MIT",
	"homepage": "https://github.com/zokugun/vscode-utils",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/zokugun/vscode-utils.git"
	},
	"bugs": {
		"url": "https://github.com/zokugun/vscode-utils/issues"
	},
	"type": "module",
	"exports": {
		".": {
			"import": "./lib/esm/index.mjs",
			"require": "./lib/cjs/index.cjs"
		}
	},
	"main": "lib/cjs/index.cjs",
	"module": "lib/esm/index.mjs",
	"typesVersions": {
		"*": {
			".": [
				"./lib/cjs/index.d.cts"
			]
		}
	},
	"scripts": {
		"audit:fix": "npm audit fix --min-release-age=0",
		"build": "npm run clean && npm run build:lib",
		"build:lib": "tsc-leda generate",
		"build:package": "tsc-leda update-package",
		"ci:lint": "zizmor .",
		"ci:lint:fix": "zizmor . --fix=all",
		"clean": "rimraf lib; rimraf .src",
		"compile:src": "tsc -p src",
		"lint": "xo",
		"lint:all": "fixpack && npm audit && npm run ci:lint && npm run lint",
		"lint:fix": "xo --fix",
		"prepack": "npm run build",
		"prepare": "husky; fixpack || true",
		"release": "release-it",
		"update:artifacts": "artifact update",
		"update:ci": "PINACT_MIN_AGE=7 pinact run",
		"update:deps": "taze",
		"watch:build": "tsc-watch -p src --onSuccess 'npm run build'",
		"watch:src": "tsc-watch -p src"
	},
	"dependencies": {
		"@zokugun/fs-extra-plus": "0.3.7",
		"@zokugun/xtry": "0.11.5"
	},
	"devDependencies": {
		"@commitlint/cli": "19.8.1",
		"@commitlint/config-conventional": "19.8.1",
		"@types/node": "20.19.39",
		"@types/vscode": "1.56.0",
		"@zokugun/tsc-leda": "0.4.0",
		"fixpack": "4.0.0",
		"husky": "9.1.7",
		"lint-staged": "16.4.0",
		"release-it": "20.0.0",
		"taze": "19.11.0",
		"tsc-watch": "7.2.0",
		"typescript": "5.9.3",
		"xo": "0.60.0"
	},
	"keywords": []
}
